# See https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files for more about ignoring files.

# dependencies
/node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# next.js
/.next/
/out/
/.turbo/
next-env.d.ts

# production
/build/
/dist/

# testing and reports
/coverage/
/playwright-report/
/test-results/

# cache
/.cache/
/.eslintcache
/.parcel-cache/
tmp/
temp/

# logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# env files
.env*
!.env.example
!.env.local.example

# deployment
.vercel/
.netlify/

# supabase
supabase/.temp/

# typescript
*.tsbuildinfo

# OS and editor files
.DS_Store
Thumbs.db
*.pem
*.swp
*.swo
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
