NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
NEXT_PUBLIC_APP_NAME=Vilique
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPPORT_EMAIL=
GOOGLE_AUTH_ENABLED=false

# Billing document configuration. Required in production before invoices can be generated.
VILIQUE_LEGAL_ENTITY_NAME=
VILIQUE_BUSINESS_ADDRESS=
VILIQUE_SUPPORT_EMAIL=
VILIQUE_GRIEVANCE_CONTACT=
VILIQUE_JURISDICTION=
VILIQUE_POLICY_EFFECTIVE_DATE=15 July 2026
VILIQUE_POLICY_LAST_UPDATED=15 July 2026
VILIQUE_GSTIN=
VILIQUE_PAN=

# Server-only. Do not expose this in client components.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Razorpay Credentials
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxx
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxx

# Server-only Razorpay Dashboard webhook secret. Use a real Test Mode secret locally.
RAZORPAY_WEBHOOK_SECRET=

# Server-only operational secrets.
PAYMENT_RECONCILIATION_SECRET=
PAYMENT_OPERATIONS_SECRET=
REQUEST_HASH_SECRET=
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.05
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.05
